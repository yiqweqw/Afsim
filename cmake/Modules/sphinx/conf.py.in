# -------------------------------------------------------------------------
# START: Create a complete site index
# -------------------------------------------------------------------------

def getDocFileSet():
   try:
      completeFileSet = set([l.strip() for l in open(indexFile, 'r').readlines()])
   except:
      pass

   for thisFile in completeFileSet:
      if thisFile.endswith('.rst') or thisFile.endswith('.md'):
         allDocFileSet.add(thisFile)
         jumpboxLetters.add(thisFile[0].upper())
         if tags.has('afsim-user-manual') and thisFile.startswith('user_manual/p'):
            userManualFileSet.add(thisFile.split('/')[1])
         if tags.has('afsim-changelog') and thisFile.endswith(str(version) + '.rst'):
            changelogFileSet.add(thisFile.split('/')[1])

def insertHeader():
   site_index.write(":orphan:")
   site_index.write("\n\n")
   site_index.write(site_index_title)
   site_index.write("\n")
   for i in site_index_title:
      site_index.write("-")
   site_index.write("\n\n")

def insertJumpbox():
   first = True
   for thisLetter in sorted(jumpboxLetters, key=lambda s: s.lower()):
      if first: first = False
      else: site_index.write("\| ")
      site_index.write(thisLetter + "_ ")
   site_index.write("\n\n")

def buildUserManualTOCTree():
   user_manual_index.write(":orphan:\n\n")
   user_manual_index.write(".. toctree::\n")
   user_manual_index.write("   :maxdepth: 1\n")
   user_manual_index.write("   :hidden:\n\n")
   for thisFile in sorted(userManualFileSet, key=lambda s: s.lower()):
      user_manual_index.write("   /" + os.path.splitext(thisFile)[0] + "\n")
   user_manual_index.write("\n")

def buildChangelogTOCTree():
   changelog_index.write(":orphan:\n\n")
   changelog_index.write(".. toctree::\n")
   changelog_index.write("   :maxdepth: 3\n")
   changelog_index.write("   :hidden:\n\n")
   for thisFile in sorted(changelogFileSet, key=lambda s: s.lower()):
      changelog_index.write("   /" + os.path.splitext(thisFile)[0] + "\n")
   changelog_index.write("\n")

def buildTOCTree():
   site_index.write(".. toctree::\n")
   site_index.write("   :maxdepth: 2\n")
   site_index.write("   :hidden:\n\n")
   for thisFile in sorted(allDocFileSet, key=lambda s: s.lower()):
      site_index.write("   /docs/" + os.path.splitext(thisFile)[0] + "\n")
   site_index.write("\n")

def buildSiteIndex():
   for thisLetter in sorted(jumpboxLetters, key=lambda s: s.lower()):
      site_index.write(thisLetter)
      site_index.write("\n")
      site_index.write("=")
      site_index.write("\n\n")
      site_index.write(".. container:: indexcontainer")
      site_index.write("\n\n")
      site_index.write("   .. hlist::")
      site_index.write("\n\n")
      for thisFile in sorted(allDocFileSet, key=lambda s: s.lower()):
         baseFile = os.path.splitext(thisFile)[0] # strip trailing extension, support .rst, .md, etc.
         if '/' in thisFile:
            (path, filename) = baseFile.rsplit('/')
            if path.lower().startswith(thisLetter.lower()):
               site_index.write("      * :doc:`" + path.upper() + ": " + filename + "</docs/" + path + "/" + filename + ">`\n")
         elif thisFile.lower().startswith(thisLetter.lower()):
            site_index.write("      * :doc:`" + baseFile + "</docs/" + baseFile + ">`\n")
      site_index.write("\n")

allDocFileSet = set()
changelogFileSet = set()
userManualFileSet = set()
jumpboxLetters = set()

getDocFileSet()

if tags.has('afsim-user-manual'):
   with open(os.path.join(docDirectory, 'user_manual/user_manual_index.rst'), 'w') as user_manual_index:
      buildUserManualTOCTree()

if tags.has('afsim-changelog'):
   with open(os.path.join(docDirectory, 'changelog/changelog_index.rst'), 'w') as changelog_index:
      buildChangelogTOCTree()

if tags.has('afsim-documentation'):
   site_index_title = "Site Index"
   with open(os.path.join(out_dir, site_index_title.replace(' ', '_').lower() + ".rst"), 'w') as site_index:
      insertHeader()
      insertJumpbox()
      buildTOCTree()
      buildSiteIndex()

# -------------------------------------------------------------------------
# END: Create a complete site index
# -------------------------------------------------------------------------
